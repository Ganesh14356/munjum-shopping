{
  "name": "munjum",
  "version": "1.0.0",
  "private": true,
  "description": "Munjum — Shop Smart, Earn More. Super Shopping, Cashback, Affiliate & Services Platform.",
  "scripts": {
    "dev": "concurrently \"next dev\" \"ts-node-dev --respawn --transpile-only server/index.ts\"",
    "dev:next": "next dev",
    "dev:api": "ts-node-dev --respawn --transpile-only server/index.ts",
    "build": "next build && tsc -p server/tsconfig.json",
    "build:next": "next build",
    "build:api": "tsc -p server/tsconfig.json",
    "start": "next start",
    "start:api": "node server/dist/index.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.4",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase": "^10.12.4",
    "firebase-admin": "^12.3.0",
    "framer-motion": "^11.3.19",
    "lucide-react": "^0.424.0",
    "next": "14.2.5",
    "next-themes": "^0.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.52.2",
    "react-hot-toast": "^2.4.1",
    "swiper": "^11.1.12",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
